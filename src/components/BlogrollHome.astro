---
import type { FeedCache, FeedPost } from "@/types";

interface Props {
	limit?: number;
}

const { limit = 3 } = Astro.props;

let cache: FeedCache = {};
try {
	cache = (await import("@/feed-cache.json")).default as unknown as FeedCache;
} catch {
	// feed-cache not generated yet
}

const allPosts: { post: FeedPost; member: { name: string; website: string } }[] = [];

for (const [website, memberData] of Object.entries(cache)) {
	for (const post of memberData.posts) {
		allPosts.push({
			post,
			member: { name: memberData.name, website: memberData.website },
		});
	}
}

allPosts.sort(
	(a, b) => new Date(b.post.published).getTime() - new Date(a.post.published).getTime(),
);

const topPosts = allPosts.slice(0, limit);
---

<section>
	<h2>latest from the webring</h2>
	{
		topPosts.length > 0 ? (
			<ul class="blogroll-list">
				{topPosts.map(({ post, member }) => (
					<li class="blogroll-entry">
						<a href={post.link}>{post.title}</a>
						<span class="blogroll-meta">
							<small>{member.name}</small>
							<small datetime={post.published}>
								{new Date(post.published).toLocaleDateString("en-US", {
									month: "short",
									day: "numeric",
									year: "numeric",
								})}
							</small>
						</span>
					</li>
				))}
			</ul>
		) : (
			<p>no recent posts yet — feeds are fetched at build time.</p>
		)
	}
	<a href="/blogroll">view all posts →</a>
</section>

<style>
	.blogroll-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.blogroll-entry {
		margin-block: 0.5rem;
	}

	.blogroll-entry a {
		display: block;
	}

	.blogroll-meta {
		display: flex;
		gap: 0.5rem;
		align-items: baseline;
	}

	.blogroll-meta small {
		color: var(--secondary-light);
	}

	@media (min-width: 600px) {
		.blogroll-entry {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			gap: 0.25rem 0.4rem;
			margin-block: 0;
		}

		.blogroll-entry a {
			display: inline;
		}
	}
</style>
