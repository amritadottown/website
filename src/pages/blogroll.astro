---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { FeedCache, FeedPost } from "@/types";
import faviconManifest from "@/favicon-manifest.json";
import RssIcon from "@/components/graphics/Rss.svg";

let cache: FeedCache = {};
try {
	cache = (await import("@/feed-cache.json")).default;
} catch {
	// not generated yet
}

interface PostWithMember {
	post: FeedPost;
	member: { name: string; website: string };
}

const allPosts: PostWithMember[] = [];

for (const [website, memberData] of Object.entries(cache)) {
	for (const post of memberData.posts) {
		allPosts.push({
			post,
			member: { name: memberData.name, website: memberData.website },
		});
	}
}

allPosts.sort(
	(a, b) => new Date(b.post.published).getTime() - new Date(a.post.published).getTime(),
);

const getFaviconSrc = (website: string) => {
	return faviconManifest[website] || "/favicon.png";
};

/** Strip HTML tags for plain-text excerpt */
/** Decode HTML entities (&#xxx; &amp; &lt; etc.) */
const decodeEntities = (text: string): string => {
	// Map of named entities to their character
	const named: Record<string, string> = {
		amp: "&",
		lt: "<",
		gt: ">",
		quot: '"',
		apos: "'",
		nbsp: " ",
		ndash: "\u2013",
		mdash: "\u2014",
		lsquo: "\u2018",
		rsquo: "\u2019",
		ldquo: "\u201c",
		rdquo: "\u201d",
		hellip: "\u2026",
		laquo: "\u00ab",
		raquo: "\u00bb",
	};
	// Iterate to handle double-encoded entities (e.g. &amp;rsquo; -> &rsquo; -> ')
	let prev: string;
	let result = text;
	do {
		prev = result;
		result = result
			.replace(/&#(\d+);/g, (_m, code) => String.fromCharCode(Number(code)))
			.replace(/&#x([0-9a-f]+);/gi, (_m, code) =>
				String.fromCharCode(parseInt(code, 16)),
			)
			.replace(/&([a-zA-Z]+);/g, (_m, name) => named[name] ?? _m);
	} while (result !== prev);
	return result;
};

const stripHtml = (html: string): string =>
	decodeEntities(html) // decode first so &#xA; -> \n, &lt; -> <
		.replace(/<[^>]*>/g, "") // then strip any HTML (including decoded &lt;...&gt;)
		.replace(/\s+/g, " ") // then collapse whitespace (catches decoded \n)
		.trim();

/** Truncate to ~N chars on word boundary */
const truncate = (text: string, max = 280): string => {
	if (text.length <= max) return text;
	const truncated = text.slice(0, max);
	const lastSpace = truncated.lastIndexOf(" ");
	return lastSpace > 0 ? truncated.slice(0, lastSpace) + "…" : truncated + "…";
};
---

<BaseLayout title="Blogroll">
	<main class="blogroll-page">
		<div class="heading-row">
			<h1>blogroll
			<a href="/blogroll.xml" class="heading-link" title="subscribe via rss">
				<RssIcon width="1.6rem" height="1.6rem" />
			</a>
			</h1>

		</div>
		<p class="subtitle">
			recent posts from the <a href="/">amrita.town</a> webring
			<a href="/blogroll.opml" class="opml-link" title="download opml">opml</a>

		</p>

		{
			allPosts.length > 0 ? (
				<div class="feed">
					{allPosts.map(({ post, member }) => (
						<article class="entry">
							<img
								src={getFaviconSrc(member.website)}
								onerror="this.onerror=null; this.src='/favicon.png';"
								alt=""
								class="avatar"
								width="24"
								height="24"
							/>
							<div class="body" style="line-height: 1.3;">
								<div class="meta">
									<span class="author">{member.name}</span>
									<time class="date" datetime={post.published}>
										{new Date(post.published).toLocaleDateString("en-US", {
											month: "short",
											day: "numeric",
											year: "numeric",
										})}
									</time>
								</div>
								<a href={post.link} class="title">
									{post.title}
								</a>
								{post.description && (
									<p class="description">
										{truncate(stripHtml(post.description), 320)}
									</p>
								)}
							</div>
						</article>
					))}
				</div>
			) : (
				<p class="empty">
					no posts yet — feeds are fetched at build time via{" "}
					<code>bun run scripts/fetch-feeds.ts</code>.
				</p>
			)
		}
	</main>
</BaseLayout>

<style>
	.heading-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.heading-row h1 {
		margin-block-end: 0;
	}

	.heading-link {
		display: inline-flex;
		align-items: center;
		color: var(--text);
	}

	.heading-link:hover {
		color: var(--accent);
	}

	.heading-link svg {
		fill: currentColor;
	}

	.subtitle {
		margin-block-end: 1.5rem;
	}

	.opml-link {
		color: var(--text);
		text-decoration: none;
		border: 1px solid var(--secondary);
		border-radius: 0.2rem;
		padding: 0.1rem 0.4rem;
		font-size: 0.75rem;
		line-height: 1;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.opml-link:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.feed {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.entry {
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 0.5rem 0.75rem;
		padding: 0.75rem 0.5rem;
		border-radius: 0.2rem;
		transition: background 0.15s;
	}

	.entry:hover {
		background-color: var(--tertiary);
		outline: 1px solid var(--secondary);
	}

	.avatar {
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 0%;
		image-rendering: pixelated;
	}

	.body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		min-width: 0;
	}

	.meta {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		line-height: 1;
		margin-bottom: 0.2em;
	}

	.author {
		font-weight: 600;
		color: var(--accent);
	}

	.date {
		color: var(--secondary-light);
	}

	.title {
		color: var(--text);
		font-weight: 500;
		text-decoration: none;
		text-transform: none;
	}

	.title:hover {
		color: var(--accent);
		text-decoration: underline;
	}

	.description {
		color: var(--secondary-light);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		text-transform: none;
	}

	.empty {
		color: var(--secondary-light);
		font-style: italic;
	}
</style>
