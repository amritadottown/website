---
import '../style.css';

interface Props {
	title: string;
}

const { title } = (Astro.props['frontmatter'] as Props) || Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		{Astro.url.pathname.startsWith('/blogroll') && <link rel="alternate" type="application/rss+xml" title="amrita.town blogroll" href="/blogroll.xml" />}
		<title>{title} - amrita.town</title>
	</head>
	<body>
		{Astro.url.pathname !== '/' && <a href="/">← back home</a>}
		<slot />
	</body>
</html>
